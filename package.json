{
  "name": "voyage-matcher",
  "private": true,
  "version": "1.0.0",
  "description": "Travel discovery and matching platform",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter client --filter server dev",
    "build": "corepack pnpm --filter shared build && corepack pnpm --filter server build && corepack pnpm --filter client build",
    "lint": "corepack pnpm -r lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json,css}\"",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@10.30.3"
}
